
  <%= render partial: "layouts/sidebar" %>

  <style>

      .card p {
          font-size: 2rem;
      }

      .container-fluid {
          margin-left: 1%;
      }
      @media only screen and (max-width: 1000px) {

          .card {
              width: 17rem !important;
              min-width: 280px;
          }

          .card h5{
              font-size: 2.25rem;
          }
          .card p {
              font-size: 3rem;
          }

          .fa-cart-plus{
             padding-left: 30%;
          }

          .pagination{
              font-size: 2.50rem;
          }

      }
  </style>

  <script>
  (function() {
    var isMobile = window.innerWidth <= 768;
    document.cookie = 'mv=' + (isMobile ? '1' : '0') + '; path=/; SameSite=Lax';
    var hasOverride = <%= (@current_user&.show_as_cards? || @current_user&.show_as_list_on_desktop?).to_json %>;
    if (!hasOverride) {
      var serverShowsCards = <%= @show_as_cards.to_json %>;
      var mismatch = (isMobile && serverShowsCards) || (!isMobile && !serverShowsCards);
      if (mismatch) {
        document.addEventListener('DOMContentLoaded', function() {
          if (typeof sendDataServer === 'function') sendDataServer();
        });
      }
    }
  })();
  </script>

  <script type="text/javascript" charset="utf-8">

      var e = document.getElementById('cart_qty');
      var ecl = document.getElementById('close_pop_cart')

      e.onclick = function () {
          document.getElementById('pop_cart').style.display = 'block';
      };
      e.onmouseout = function () {
          // document.getElementById('pop_cart').style.display = 'none';
      }
      onclickPopCart = function () {
          document.getElementById('pop_cart').style.display = 'none';
      }
  </script>

