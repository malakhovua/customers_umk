<style>
    :root {
        --azure:        #1A7AAF;
        --azure-light:  #3AA0D8;
        --azure-bright: #0EA5E9;
        --teal:         #0E7490;
        --bg:           #F0F8FF;
        --surface:      #FFFFFF;
        --border:       #BAE0F5;
        --border-soft:  #D4EDF9;
        --text:         #0B2A3D;
        --muted:        #4A7A96;
        --red:          #C0392B;
        --green:        #0E7040;
        --green-light:  #16A35A;
    }

    /* ===== СІТКА ПРОДУКТІВ ===== */
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        padding: 20px 0 10px;
    }

    /* ===== КАРТКА ПРОДУКТУ ===== */
    .product-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.28s ease, border-color 0.28s ease, box-shadow 0.28s ease;
        box-shadow: 0 2px 10px rgba(26,122,175,0.07);
    }

    .product-card:hover {
        transform: translateY(-4px);
        border-color: var(--azure-light);
        box-shadow: 0 12px 32px rgba(26,122,175,0.14);
    }

    /* Зона зображення */
    .product-card__img-wrap {
        background: linear-gradient(145deg, #EBF6FF, #D6EDFA);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 18px;
        border-bottom: 1px solid var(--border-soft);
        position: relative;
    }

    .product-card__img-wrap img {
        width: 170px;
        height: 170px;
        object-fit: contain;
        border-radius: 10px;
    }

    /* Тіло картки */
    .product-card__body {
        padding: 14px 16px 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
    }

    .product-card__category {
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--azure-light);
        font-weight: 600;
    }

    .product-card__title {
        font-family: 'Playfair Display', serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        line-height: 1.3;
        margin: 0;
    }

    /* Рядок ціни (кг) */
    .product-card__price-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 8px;
        padding-top: 8px;
        border-top: 1px solid var(--border-soft);
    }

    .product-card__price {
        font-size: 18px;
        font-weight: 800;
        color: var(--azure);
        font-family: 'Playfair Display', serif;
        letter-spacing: -0.01em;
    }

    /* Кнопка додати в кошик */
    .btn-add-cart {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px; height: 36px;
        border-radius: 10px;
        background: rgba(26,122,175,0.10);
        border: 1px solid rgba(26,122,175,0.22);
        color: var(--azure);
        font-size: 16px;
        text-decoration: none;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
        flex-shrink: 0;
    }

    .btn-add-cart:hover {
        background: rgba(26,122,175,0.20);
        transform: scale(1.10);
        box-shadow: 0 4px 12px rgba(26,122,175,0.20);
        color: var(--azure);
    }

    /* Список пакувань */
    .product-card__packs {
        list-style: none;
        margin: 0;
        padding: 0;
        border-top: 1px solid var(--border-soft);
    }

    .product-card__pack-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 9px 16px;
        border-bottom: 1px solid rgba(186,224,245,0.35);
        transition: background 0.18s;
        gap: 8px;
    }

    .product-card__pack-item:last-child { border-bottom: none; }
    .product-card__pack-item:hover { background: rgba(26,122,175,0.03); }

    .pack-name {
        font-size: 12px;
        color: var(--muted);
        font-family: 'Montserrat', sans-serif;
        flex: 1;
        min-width: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pack-price-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .pack-price {
        font-size: 14px;
        font-weight: 700;
        color: var(--green-light);
        white-space: nowrap;
    }

    .btn-add-cart.green {
        background: rgba(14,112,64,0.09);
        border-color: rgba(14,112,64,0.22);
        color: var(--green-light);
    }

    .btn-add-cart.green:hover {
        background: rgba(14,112,64,0.18);
        box-shadow: 0 4px 12px rgba(14,112,64,0.18);
        color: var(--green);
    }

    /* ===== ПАГІНАЦІЯ ===== */
    .products-footer {
        display: flex;
        justify-content: center;
        padding: 28px 0 8px;
    }

    /* Базова структура pagination — Bootstrap відсутній */
    .products-footer .pagination {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: wrap !important;
        align-items: center !important;
        list-style: none !important;
        padding-left: 0 !important;
        margin: 0 !important;
        gap: 4px !important;
    }

    .products-footer .pagination .page-item {
        display: inline-flex !important;
        list-style: none !important;
    }

    /* Скидаємо стандартний колір браузерних посилань */
    .products-footer .pagination a,
    .products-footer .pagination a:visited,
    .products-footer .pagination a:link {
        color: var(--azure-light) !important;
        text-decoration: none !important;
    }

    .products-footer .pagination .page-item .page-link {
        background: var(--surface) !important;
        border: 1px solid var(--border) !important;
        color: var(--azure) !important;
        border-radius: 8px !important;
        margin: 0 2px !important;
        font-family: 'Montserrat', sans-serif !important;
        font-size: 13px !important;
        font-weight: 600 !important;
        padding: 6px 12px !important;
        text-decoration: none !important;
        transition: background 0.2s, border-color 0.2s;
    }

    .products-footer .pagination .page-item .page-link:hover {
        background: rgba(26,122,175,0.08) !important;
        border-color: var(--azure-light) !important;
        color: var(--azure) !important;
    }

    .products-footer .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, var(--azure-light), var(--azure)) !important;
        border-color: var(--azure) !important;
        color: #fff !important;
        box-shadow: 0 3px 10px rgba(26,122,175,0.25) !important;
    }

    .products-footer .pagination .page-item.disabled .page-link {
        background: var(--bg) !important;
        border-color: var(--border-soft) !important;
        color: var(--muted) !important;
        opacity: 0.6 !important;
        cursor: not-allowed !important;
    }

    /* Mobile */
    @media (max-width: 600px) {
        /* Базова структура pagination — Bootstrap відсутній */
        .products-footer .pagination {
            display: flex !important;
            flex-direction: row !important;
            flex-wrap: wrap !important;
            align-items: center !important;
            list-style: none !important;
            padding-left: 0 !important;
            margin: 0 !important;
            gap: 4px !important;
        }

        .products-footer .pagination .page-item {
            display: inline-flex !important;
            list-style: none !important;
        }

        /* Скидаємо стандартний колір браузерних посилань */
        .products-footer .pagination a,
        .products-footer .pagination a:visited,
        .products-footer .pagination a:link {
            color: var(--azure-light) !important;
            text-decoration: none !important;
        }

        .products-footer .pagination .page-item .page-link {
            font-size: 15px !important;
            padding: 10px 14px !important;
            min-width: 44px !important;
            min-height: 44px !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
        }
    }
</style>

<div class="products-grid">
  <% @products.each do |product| %>
    <% next if product.belong_another_client(@client_id) %>

    <div class="product-card">

      <%# Зображення %>
      <div class="product-card__img-wrap">
        <% img = product['image_url'].presence || 'placeholder.jpg' %>
        <%= image_tag img, width: 170, height: 170 rescue '' %>
      </div>

      <%# Тіло %>
      <div class="product-card__body">
        <div class="product-card__category"><%= product.parent_name %></div>
        <h5 class="product-card__title"><%= product.title %></h5>

        <div class="product-card__price-row">
          <span class="product-card__price">
            <%= sprintf("%0.02f грн.", Product.get_price(product.id, @price_type)) %>
          </span>

          <% if @client_id.nil? %>
            <%= link_to "#",
                        class: "btn-add-cart",
                        title: "Додати в кошик",
                        "data-confirm": "Оберіть замовника",
                        remote: true do %>
              <i class="fa fa-cart-plus"></i>
            <% end %>
          <% else %>
            <%= link_to modal_product_qty_path(
                          id: product.id, pack_id: nil,
                          product_name: product.title,
                          pack_name: '', unit_name: 'кг'),
                        class: "btn-add-cart",
                        title: "Додати в кошик",
                        "data-toggle": "modal",
                        "data-target": "#modal-window",
                        remote: true do %>
              <i class="fa fa-cart-plus"></i>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Пакування %>
      <% packs = product_packs(product) %>
      <% if packs.any? %>
        <ul class="product-card__packs">
          <% packs.each do |pack| %>
            <li class="product-card__pack-item">
              <span class="pack-name"><%= pack.name %></span>
              <div class="pack-price-row">
                <span class="pack-price">
                  <%= sprintf("%0.02f грн.", Product.get_price(product.id, @price_type, pack.id)) %>
                </span>

                <% if @client_id.nil? %>
                  <%= link_to "#",
                              class: "btn-add-cart green",
                              title: "Додати в кошик",
                              "data-confirm": "Оберіть замовника",
                              remote: true do %>
                    <i class="fa fa-cart-plus"></i>
                  <% end %>
                <% else %>
                  <%= link_to modal_product_qty_path(
                                id: product.id, pack_id: pack.id,
                                product_name: product.title,
                                pack_name: pack.name, unit_name: 'шт'),
                              class: "btn-add-cart green",
                              title: "Додати в кошик",
                              "data-toggle": "modal",
                              "data-target": "#modal-window",
                              remote: true do %>
                    <i class="fa fa-cart-plus"></i>
                  <% end %>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      <% end %>

    </div>
  <% end %>
</div>

<%# ===== ПАГІНАЦІЯ ===== %>
<div class="products-footer">
  <span><%= paginate @products, remote: true %></span>
</div>