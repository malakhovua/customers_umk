<style>
    :root {
        --azure:        #1A7AAF;
        --azure-light:  #3AA0D8;
        --bg:           #F0F8FF;
        --surface:      #FFFFFF;
        --border:       #BAE0F5;
        --border-soft:  #D4EDF9;
        --text:         #0B2A3D;
        --muted:        #4A7A96;
        --green:        #0E7040;
        --teal:         #0E7490;
        --red:          #C0392B;
    }

    /* Breadcrumb */
    .ei-show-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .ei-show-breadcrumb a {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        color: var(--azure);
        text-decoration: none;
        font-weight: 600;
        padding: 5px 14px;
        border-radius: 20px;
        background: rgba(26,122,175,0.07);
        border: 1px solid rgba(26,122,175,0.18);
        transition: background 0.2s;
        white-space: nowrap;
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
    }
    .ei-show-breadcrumb a:hover { background: rgba(26,122,175,0.14); color: var(--azure); }

    /* Notice */
    .ei-show-notice {
        background: rgba(14,112,64,0.08);
        border: 1px solid rgba(14,112,64,0.2);
        border-radius: 10px;
        padding: 10px 16px;
        color: var(--green);
        font-size: 13px;
        margin-bottom: 20px;
        font-family: 'Montserrat', sans-serif;
    }

    /* Заголовок */
    .ei-show-header {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(26,122,175,0.08);
        margin-bottom: 20px;
    }

    .ei-show-title-bar {
        background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
        border-bottom: 2px solid var(--border);
        padding: 18px 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .ei-show-title {
        font-family: 'Playfair Display', serif;
        font-size: 20px;
        font-weight: 800;
        color: var(--text);
        flex: 1;
    }

    .ei-show-date {
        font-size: 13px;
        color: var(--muted);
        font-family: 'Montserrat', sans-serif;
        background: rgba(26,122,175,0.08);
        border: 1px solid rgba(26,122,175,0.15);
        border-radius: 20px;
        padding: 3px 12px;
    }

    /* Тип документу — бейдж у заголовку */
    .ei-doc-type-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 14px;
        border-radius: 20px;
        font-family: 'Montserrat', sans-serif;
        font-size: 12px;
        font-weight: 700;
        background: rgba(14,116,144,0.10);
        border: 1px solid rgba(14,116,144,0.22);
        color: var(--teal);
    }

    /* Деталі — стиль 1С */
    .ei-show-details {
        padding: 8px 24px 4px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 24px;
    }

    @media (max-width: 768px) {
        .ei-show-details { grid-template-columns: 1fr; }
    }

    .ei-detail-item {
        display: flex;
        align-items: baseline;
        padding: 5px 0;
        border-bottom: 1px solid rgba(186,224,245,0.3);
        font-family: 'Montserrat', sans-serif;
        gap: 6px;
    }

    .ei-detail-label {
        font-size: 12px;
        color: var(--muted);
        font-weight: 500;
        white-space: nowrap;
        min-width: 160px;
        flex-shrink: 0;
    }

    .ei-detail-dots {
        flex: 1;
        border-bottom: 1px dotted #BAE0F5;
        margin-bottom: 3px;
        min-width: 10px;
    }

    .ei-detail-value {
        font-size: 13px;
        color: var(--text);
        font-weight: 600;
        white-space: nowrap;
        text-align: right;
    }

    .ei-detail-value.azure { color: var(--azure); }
    .ei-detail-value.teal  { color: var(--teal); }

    /* Таблиця позицій */
    .ei-items-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(26,122,175,0.08);
        margin-bottom: 20px;
        overflow-x: auto;
    }

    .ei-items-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        font-family: 'Montserrat', sans-serif;
    }

    .ei-items-table thead tr {
        background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
        border-bottom: 2px solid var(--border);
    }

    .ei-items-table thead th {
        padding: 11px 14px;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--azure);
        font-weight: 700;
        white-space: nowrap;
        text-align: left;
    }

    .ei-items-table tbody tr {
        border-bottom: 1px solid rgba(186,224,245,0.4);
        transition: background 0.15s;
    }
    .ei-items-table tbody tr:last-child { border-bottom: none; }
    .ei-items-table tbody tr:hover { background: rgba(26,122,175,0.03); }
    .ei-items-table td {
        padding: 10px 14px;
        color: var(--text);
        vertical-align: middle;
    }

    /* Підсумок */
    .ei-summary {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(26,122,175,0.08);
        margin-bottom: 20px;
    }

    .ei-summary-head {
        background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
        padding: 13px 22px;
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--azure);
        border-bottom: 1px solid var(--border);
        font-family: 'Montserrat', sans-serif;
    }

    .ei-summary-body { padding: 16px 22px; }

    .ei-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 11px 0;
        border-bottom: 1px solid rgba(186,224,245,0.4);
        font-size: 14px;
        font-family: 'Montserrat', sans-serif;
    }
    .ei-summary-row:last-child { border-bottom: none; }
    .ei-summary-row span { color: var(--muted); font-weight: 500; }

    .ei-summary-val {
        font-size: 18px;
        font-weight: 800;
        color: var(--text);
    }
    .ei-summary-val.azure { color: var(--azure); }

    /* ===== MOBILE: картки позицій ===== */
    .ei-items-cards { display: none !important; }

    @media (max-width: 600px) {
        .ei-show-breadcrumb a { font-size: 14px; padding: 9px 14px; min-height: 44px; }
        .ei-show-title-bar { padding: 14px 16px; }
        .ei-show-title { font-size: 17px; }
        .ei-show-details { grid-template-columns: 1fr !important; padding: 8px 16px 4px; }
        .ei-detail-label { min-width: 130px; font-size: 11px; }
        .ei-detail-value { font-size: 12px; }

        /* Ховаємо таблицю, показуємо картки */
        .ei-items-wrap { display: none !important; }
        .ei-items-cards { display: flex !important; flex-direction: column; gap: 10px; margin-bottom: 20px; }

        .ei-item-card {
            background: #FFFFFF;
            border: 1px solid #BAE0F5;
            border-radius: 14px;
            overflow: hidden;
            font-family: 'Montserrat', sans-serif;
            box-shadow: 0 2px 8px rgba(26,122,175,0.07);
        }
        .ei-item-card-title {
            background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
            padding: 10px 14px;
            font-size: 14px;
            font-weight: 700;
            color: #0B2A3D;
            border-bottom: 1px solid #BAE0F5;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .ei-item-num {
            background: #1A7AAF;
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 10px;
            flex-shrink: 0;
        }
        .ei-item-card-body { padding: 10px 14px; display: flex; flex-direction: column; gap: 7px; }
        .ei-item-row { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
        .ei-item-label { font-size: 12px; color: #4A7A96; font-weight: 500; flex-shrink: 0; }
        .ei-item-value { font-size: 13px; font-weight: 600; color: #0B2A3D; text-align: right; }
        .ei-item-value.azure { color: #1A7AAF; }
        .ei-item-value.green { color: #0E7040; font-size: 15px; }

        .ei-summary-body { padding: 12px 16px; }
        .ei-summary-val { font-size: 20px; }
    }
</style>

<%# BREADCRUMB %>
<div class="ei-show-breadcrumb">
  <%= link_to expense_invoices_url do %>
    <i class="fa fa-list"></i> До списку накладних
  <% end %>
  <%= link_to account_url do %>
    <i class="fa fa-home"></i> На головну
  <% end %>
</div>

<%# NOTICE %>
<% if notice.present? %>
  <div class="ei-show-notice"><%= notice %></div>
<% end %>

<%# ЗАГОЛОВОК %>
<div class="ei-show-header">
  <div class="ei-show-title-bar">
    <div class="ei-show-title">
      Видаткова накладна №<%= @expense_invoice.number.presence || @expense_invoice.id %>
    </div>
    <span class="ei-doc-type-badge">
      <%= ExpenseInvoice.doc_types.key(@expense_invoice.doc_type.to_i) || @expense_invoice.doc_type %>
    </span>
    <span class="ei-show-date">
      <i class="fa fa-calendar" style="margin-right:4px;"></i>
      <%= @expense_invoice.doc_date&.strftime("%d.%m.%Y") %>
    </span>
  </div>

  <div class="ei-show-details">
    <div class="ei-detail-item">
      <span class="ei-detail-label">Контрагент:</span>
      <span class="ei-detail-dots"></span>
      <span class="ei-detail-value"><%= @expense_invoice.client&.name || '—' %></span>
    </div>
    <div class="ei-detail-item">
      <span class="ei-detail-label">Група доступу:</span>
      <span class="ei-detail-dots"></span>
      <span class="ei-detail-value teal">
        <%= @expense_invoice.access_group&.name || '—' %>
      </span>
    </div>
    <div class="ei-detail-item">
      <span class="ei-detail-label">Замовлення:</span>
      <span class="ei-detail-dots"></span>
      <span class="ei-detail-value">
        <% if @expense_invoice.order.present? %>
          №<%= @expense_invoice.order.id %> від <%= @expense_invoice.order.date&.strftime("%d.%m.%Y") %>
        <% else %>
          —
        <% end %>
      </span>
    </div>
    <div class="ei-detail-item">
      <span class="ei-detail-label">Коментар:</span>
      <span class="ei-detail-dots"></span>
      <span class="ei-detail-value"><%= @expense_invoice.comment.presence || '—' %></span>
    </div>
  </div>
</div>

<%# ТАБЛИЦЯ ПОЗИЦІЙ (desktop) %>
<div class="ei-items-wrap">
  <table class="ei-items-table">
    <thead>
    <tr>
      <th>#</th>
      <th>Продукція</th>
      <th>Упаковка</th>
      <th>Од.</th>
      <th>Кількість</th>
      <th>Ціна</th>
      <th>Ціна, роздріб</th>
      <th>Сума</th>
      <th>Сума роздріб</th>
      <th>Коментар</th>
    </tr>
    </thead>
    <tbody>
    <% n = 1 %>
    <% @expense_invoice.line_item_expense_invoices.order(:id).each do |item| %>
      <tr>
        <td><%= n %></td>
        <td><strong><%= item.product&.title || item.product&.name %></strong></td>
        <td><%= item.pack&.name || '—' %></td>
        <td><%= item.unit_product&.name %></td>
        <td><%= item.qty %></td>
        <td><%= sprintf("%.2f грн.", item.price.to_f) %></td>
        <td><%= sprintf("%.2f грн.", item.retail_price.to_f) %></td>
        <td><strong><%= sprintf("%.2f грн.", item.sum.to_f) %></strong></td>
        <td><%= sprintf("%.2f грн.", item.retail_sum.to_f) %></td>
        <td><%= item.comment.presence || '—' %></td>
      </tr>
      <% n += 1 %>
    <% end %>
    </tbody>
  </table>
</div>

<%# MOBILE: КАРТКИ ПОЗИЦІЙ %>
<div class="ei-items-cards">
  <% n = 1 %>
  <% @expense_invoice.line_item_expense_invoices.order(:id).each do |item| %>
    <div class="ei-item-card">
      <div class="ei-item-card-title">
        <span class="ei-item-num"><%= n %></span>
        <%= item.product&.title || item.product&.name %>
        <% if item.pack.present? %>
          <span style="font-size:11px;font-weight:500;color:#4A7A96;">· <%= item.pack.name %></span>
        <% end %>
      </div>
      <div class="ei-item-card-body">
        <div class="ei-item-row">
          <span class="ei-item-label">Одиниця</span>
          <span class="ei-item-value"><%= item.unit_product&.name %></span>
        </div>
        <div class="ei-item-row">
          <span class="ei-item-label">Кількість</span>
          <span class="ei-item-value azure"><%= item.qty %></span>
        </div>
        <div class="ei-item-row">
          <span class="ei-item-label">Ціна</span>
          <span class="ei-item-value"><%= sprintf("%.2f грн.", item.price.to_f) %></span>
        </div>
        <div class="ei-item-row">
          <span class="ei-item-label">Ціна, роздріб</span>
          <span class="ei-item-value"><%= sprintf("%.2f грн.", item.retail_price.to_f) %></span>
        </div>
        <div class="ei-item-row">
          <span class="ei-item-label">Сума</span>
          <span class="ei-item-value green"><%= sprintf("%.2f грн.", item.sum.to_f) %></span>
        </div>
        <div class="ei-item-row">
          <span class="ei-item-label">Сума роздріб</span>
          <span class="ei-item-value"><%= sprintf("%.2f грн.", item.retail_sum.to_f) %></span>
        </div>
        <% if item.comment.present? %>
          <div class="ei-item-row">
            <span class="ei-item-label">Коментар</span>
            <span class="ei-item-value"><%= item.comment %></span>
          </div>
        <% end %>
      </div>
    </div>
    <% n += 1 %>
  <% end %>
</div>

<%# ПІДСУМОК %>
<div class="ei-summary">
  <div class="ei-summary-head">Підсумки накладної</div>
  <div class="ei-summary-body">
    <div class="ei-summary-row">
      <span>Сума (оптова):</span>
      <div class="ei-summary-val azure">
        <%= sprintf("%.2f грн.", @expense_invoice.sum.to_f) %>
      </div>
    </div>
    <div class="ei-summary-row">
      <span>Сума (роздрібна):</span>
      <div class="ei-summary-val">
        <%= sprintf("%.2f грн.", @expense_invoice.retail_sum.to_f) %>
      </div>
    </div>
  </div>
</div>