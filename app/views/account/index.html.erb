<div class="container">
  <div class="welcome">
      <h2 class="display-10 text-center">Ласкаво просимо до сайту замовлень УКРАЇНСЬКОГО М'ЯСОКОМБІНАТУ!</h2>
      <h2 class="display-10 text-center">Ви увійшли як <%= current_user.name%>.</h2>
  </div>
  <div class="row">
    <%unless current_user.retailer? %>
    <%= link_to customer_index_url,class: "col-md-4", :action => 'go' do %>
    <div class="card border-info mb-3" style="max-width: 18rem;">
      <div class="card-body text-info">
        <p class="card-text text-center"><i class="fa fa-shopping-basket" aria-hidden="true" style="font-size: 60px; color: darkturquoise;"></i></p>
        <h5 class="card-title text-center">Оформити замовлення</h5>
      </div>
    </div>
      <% end %>
  <% end %>
    <%unless current_user.retailer? %>
    <%= link_to orders_url,class: "col-md-4", :action => 'go' do %>
      <div class="card border-info mb-3" style="max-width: 18rem;">
        <div class="card-body text-info">
          <p class="card-text text-center"><i class="fa fa-file-text-o" aria-hidden="true" style="font-size: 60px; color: darkturquoise;"></i></p>
          <h5 class="card-title text-center">Мої замовлення</h5>
        </div>
      </div>
      <% end %>
    <% end %>
    <% if current_user.admin? %>
    <%= link_to clients_url,class: "col-md-4", :action => 'go' do %>
      <div class="card border-info mb-3" style="max-width: 18rem;">
        <div class="card-body text-info">
          <p class="card-text text-center"><i class="fa fa-address-book-o" aria-hidden="true" style="font-size: 60px; color: darkturquoise;"></i></p>
          <h5 class="card-title text-center">Покупці</h5>
        </div>
      </div>
    <% end %>
      <%end%>
    <%= link_to edit_user_path(current_user),class: "col-md-4", :action => 'go' do %>
      <div class="card border-info mb-3" style="max-width: 18rem;">
        <div class="card-body text-info">
          <p class="card-text text-center"><i class="fa fa-user-circle-o" aria-hidden="true" style="font-size: 60px; color: darkturquoise;"></i></p>
          <h5 class="card-title text-center">Профіль</h5>
        </div>
      </div>
    <% end %>
    <% if current_user.admin? %>
    <%= link_to admin_path,class: "col-md-4", :action => 'go' do %>
      <div class="card border-info mb-3" style="max-width: 18rem;">
        <div class="card-body text-info">
          <p class="card-text text-center"><i class="fa fa-wrench" aria-hidden="true" style="font-size: 60px; color: darkturquoise;"></i></p>
          <h5 class="card-title text-center">Адміністрування</h5>
        </div>
      </div>
        <%end%>
    <% end %>
    <%unless current_user.user? %>
    <%= link_to inventories_url ,class: "col-md-4", :action => 'go' do %>
      <div class="card border-info mb-3" style="max-width: 18rem;">
        <div class="card-body text-info">
          <p class="card-text text-center"><i class="fa fa-list-alt" aria-hidden="true" style="font-size: 60px; color: darkturquoise;"></i></p>
          <h5 class="card-title text-center">Інвентаризації</h5>
        </div>
      </div>
      <% end %>
    <% end %>
  </div>
    <%= link_to logout_path ,class: "col-md-4", method: :delete, :action => 'go' do %>
      <div class="card border-info mb-3" style="max-width: 18rem;">
        <div class="card-body text-info">
          <p class="card-text text-center"><i class="fa fa-sign-out" aria-hidden="true" style="font-size: 60px; color: darkturquoise;"></i></p>
          <h5 class="card-title text-center">Вийти</h5>
        </div>
      </div>
    <% end %>
</div>

<style>

  .welcome{
      background-color:azure;
      box-shadow: 0 10px 15px rgba(0, 0, 0, 0.3);
      margin-top: 5%;
      margin-bottom: 5%;
  }

  .welcome h2 {
      padding: 15px;

  }

    @media only screen and (max-width: 1000px) {

        .container {
                max-width: 1000px;
            margin: 10px;
            }

        .card {
            height: 400px;
            min-width: 310px;
        }

        h2 {
            font-size: 3.00rem;
        }

        h5 {
            font-size: 3.00rem;
        }

    }

</style>









