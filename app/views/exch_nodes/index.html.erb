<style>
    :root {
        --azure:        #1A7AAF;
        --azure-light:  #3AA0D8;
        --bg:           #F0F8FF;
        --surface:      #FFFFFF;
        --border:       #BAE0F5;
        --border-soft:  #D4EDF9;
        --text:         #0B2A3D;
        --muted:        #4A7A96;
        --red:          #C0392B;
    }
    .en-breadcrumb {
        display: flex; align-items: center; gap: 6px; margin-bottom: 24px; flex-wrap: wrap;
    }
    .en-breadcrumb a {
        display: inline-flex; align-items: center; gap: 5px; color: var(--azure);
        text-decoration: none; font-weight: 600; padding: 6px 14px; border-radius: 20px;
        font-size: 13px; background: rgba(26,122,175,0.07); border: 1px solid rgba(26,122,175,0.18);
        font-family: 'Montserrat', sans-serif; transition: background 0.2s;
    }
    .en-breadcrumb a:hover { background: rgba(26,122,175,0.14); text-decoration: none; color: var(--azure); }
    .en-breadcrumb span { color: var(--muted); font-size: 13px; font-family: 'Montserrat', sans-serif; }
    .en-notice {
        background: rgba(14,112,64,0.08); border: 1px solid rgba(14,112,64,0.2);
        border-radius: 10px; padding: 10px 16px; color: #0E7040;
        font-size: 13px; margin-bottom: 16px; font-family: 'Montserrat', sans-serif;
    }
    .en-page-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 20px; flex-wrap: wrap; gap: 12px;
    }
    .en-page-title {
        font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 800;
        color: var(--text); display: flex; align-items: center; gap: 10px;
    }
    .en-page-title::before {
        content: ''; display: inline-block; width: 5px; height: 24px;
        background: linear-gradient(180deg, var(--azure-light), var(--azure)); border-radius: 3px;
    }
    .en-btn-new {
        display: inline-flex; align-items: center; gap: 7px; padding: 9px 20px;
        background: linear-gradient(135deg, var(--azure-light), var(--azure));
        border: none; border-radius: 10px; color: #fff; font-size: 13px; font-weight: 700;
        font-family: 'Montserrat', sans-serif; text-decoration: none;
        transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 3px 12px rgba(26,122,175,0.25);
    }
    .en-btn-new:hover { opacity: 0.92; transform: translateY(-1px); color: #fff; text-decoration: none; }
    .en-table-wrap {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: 16px; overflow-x: auto;
        box-shadow: 0 2px 12px rgba(26,122,175,0.07);
        margin-bottom: 8px; -webkit-overflow-scrolling: touch;
    }
    .en-table {
        width: 100%; min-width: 600px; border-collapse: collapse;
        font-size: 13px; font-family: 'Montserrat', sans-serif;
    }
    .en-table thead tr { background: linear-gradient(135deg, #E0F2FF, #C8E8FA); border-bottom: 2px solid var(--border); }
    .en-table thead th {
        padding: 11px 16px; font-size: 10px; letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--azure); font-weight: 700; white-space: nowrap;
        position: sticky; top: 0; background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
        z-index: 2; box-shadow: 0 2px 0 var(--border); text-align: left;
    }
    .en-table tbody tr { border-bottom: 1px solid rgba(186,224,245,0.4); transition: background 0.15s; }
    .en-table tbody tr:last-child { border-bottom: none; }
    .en-table tbody tr:hover { background: rgba(26,122,175,0.04); }
    .en-table td { padding: 10px 16px; color: var(--text); vertical-align: middle; }
    .en-muted { color: var(--muted); font-size: 12px; }
    .en-action {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px; border-radius: 8px; font-size: 13px;
        text-decoration: none; transition: background 0.2s, transform 0.15s;
    }
    .en-action-show   { color: var(--azure); background: rgba(26,122,175,0.07); border: 1px solid rgba(26,122,175,0.15); }
    .en-action-show:hover   { background: rgba(26,122,175,0.14); transform: scale(1.08); color: var(--azure); text-decoration: none; }
    .en-action-edit   { color: #0E7490; background: rgba(14,116,144,0.07); border: 1px solid rgba(14,116,144,0.15); }
    .en-action-edit:hover   { background: rgba(14,116,144,0.14); transform: scale(1.08); color: #0E7490; text-decoration: none; }
    .en-action-delete { color: var(--red); background: rgba(192,57,43,0.07); border: 1px solid rgba(192,57,43,0.15); }
    .en-action-delete:hover { background: rgba(192,57,43,0.14); transform: scale(1.08); color: var(--red); text-decoration: none; }
</style>

<div class="en-breadcrumb">
  <%= link_to account_url do %><i class="fa fa-home"></i> На головну<% end %>
  <span>/</span>
  <%= link_to admin_url do %><i class="fa fa-cogs"></i> Адміністрування<% end %>
  <span>/</span>
  <span>Вузли обміну</span>
</div>

<% if notice.present? %>
  <div class="en-notice"><%= notice %></div>
<% end %>

<div class="en-page-header">
  <div class="en-page-title">Вузли обміну з 1С 8.3</div>
  <%= link_to new_exch_node_path, class: 'en-btn-new' do %>
    <i class="fa fa-plus"></i> Новий вузол
  <% end %>
</div>

<div class="en-table-wrap">
  <table class="en-table">
    <thead>
    <tr>
      <th>Код УНФ</th>
      <th>Вузол</th>
      <th>Сервер</th>
      <th>Каталог HTTP</th>
      <th colspan="3"></th>
    </tr>
    </thead>
    <tbody>
    <% @exch_nodes.each do |exch_node| %>
      <tr>
        <td class="en-muted"><%= exch_node.code_unf %></td>
        <td><strong><%= exch_node.node %></strong></td>
        <td><%= exch_node.ser %></td>
        <td><%= exch_node.cat %></td>
        <td>
          <%= link_to exch_node, class: 'en-action en-action-show', title: 'Показати' do %>
            <i class="fa fa-eye"></i>
          <% end %>
        </td>
        <td>
          <%= link_to edit_exch_node_path(exch_node), class: 'en-action en-action-edit', title: 'Редагувати' do %>
            <i class="fa fa-pencil"></i>
          <% end %>
        </td>
        <td>
          <%= link_to exch_node, method: :delete, data: { confirm: 'Ви впевнені?' }, class: 'en-action en-action-delete', title: 'Видалити' do %>
            <i class="fa fa-trash"></i>
          <% end %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>