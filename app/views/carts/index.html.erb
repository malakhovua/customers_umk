<style>
    :root {
        --azure:        #1A7AAF;
        --azure-light:  #3AA0D8;
        --azure-bright: #0EA5E9;
        --bg:           #F0F8FF;
        --surface:      #FFFFFF;
        --border:       #BAE0F5;
        --border-soft:  #D4EDF9;
        --text:         #0B2A3D;
        --muted:        #4A7A96;
        --red:          #C0392B;
        --green:        #0E7040;
    }

    /* Breadcrumb */
    .cart-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 24px;
        font-size: 13px;
        flex-wrap: wrap;
    }

    .cart-breadcrumb a {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        color: var(--azure);
        text-decoration: none;
        font-weight: 600;
        padding: 5px 12px;
        border-radius: 20px;
        background: rgba(26,122,175,0.07);
        border: 1px solid rgba(26,122,175,0.18);
        transition: background 0.2s;
        white-space: nowrap;
        font-family: 'Montserrat', sans-serif;
    }

    .cart-breadcrumb a:hover { background: rgba(26,122,175,0.14); }

    /* Заголовок */
    .cart-page-title {
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cart-page-title::before {
        content: '';
        display: inline-block;
        width: 5px; height: 26px;
        background: linear-gradient(180deg, var(--azure-light), var(--azure));
        border-radius: 3px;
        flex-shrink: 0;
    }

    /* ===== DESKTOP: Таблиця ===== */
    .cart-table-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(26,122,175,0.08);
    }

    .cart-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        font-family: 'Montserrat', sans-serif;
    }

    .cart-table thead tr {
        background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
        border-bottom: 2px solid var(--border);
    }

    .cart-table thead th {
        padding: 13px 16px;
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--azure);
        font-weight: 700;
        white-space: nowrap;
        text-align: left;
    }

    .cart-table tbody tr {
        border-bottom: 1px solid rgba(186,224,245,0.4);
        transition: background 0.18s;
    }

    .cart-table tbody tr:last-child { border-bottom: none; }
    .cart-table tbody tr:hover { background: rgba(26,122,175,0.04); }
    .cart-table tbody tr.is-current { background: rgba(14,112,64,0.05); }
    .cart-table tbody tr.is-current:hover { background: rgba(14,112,64,0.09); }

    .cart-table td {
        padding: 12px 16px;
        color: var(--text);
        vertical-align: middle;
    }

    .cart-num   { font-weight: 700; color: var(--muted); }
    .cart-qty   { color: var(--azure); font-weight: 600; }
    .cart-price { color: var(--text); font-weight: 700; }

    .cart-current-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        color: var(--green);
        background: rgba(14,112,64,0.09);
        border: 1px solid rgba(14,112,64,0.2);
        white-space: nowrap;
    }

    .cart-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px; height: 32px;
        border-radius: 8px;
        font-size: 15px;
        text-decoration: none;
        transition: background 0.2s, transform 0.15s;
    }

    .cart-action-open {
        color: var(--azure);
        background: rgba(26,122,175,0.08);
        border: 1px solid rgba(26,122,175,0.18);
    }

    .cart-action-open:hover {
        background: rgba(26,122,175,0.16);
        transform: scale(1.08);
        color: var(--azure);
    }

    .cart-action-delete {
        color: var(--red);
        background: rgba(192,57,43,0.07);
        border: 1px solid rgba(192,57,43,0.18);
    }

    .cart-action-delete:hover {
        background: rgba(192,57,43,0.14);
        transform: scale(1.08);
        color: var(--red);
    }

    .cart-actions-cell {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    /* ===== MOBILE: Картки замість таблиці ===== */
    .cart-cards { display: none !important; }

    @media (max-width: 600px) {
        .cart-table-wrap { display: none !important; }
        .cart-cards { display: flex !important; flex-direction: column; gap: 12px; }

        .cart-page-title { font-size: 20px !important; margin-bottom: 16px !important; }

        .cart-breadcrumb {
            gap: 8px;
            margin-bottom: 16px;
        }

        .cart-breadcrumb a {
            font-size: 14px;
            padding: 8px 14px;
        }

        /* Картка кошика */
        .cart-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: 0 2px 10px rgba(26,122,175,0.07);
            overflow: hidden;
        }

        .cart-card.is-current {
            border-color: rgba(14,112,64,0.35);
            box-shadow: 0 2px 10px rgba(14,112,64,0.1);
        }

        .cart-card-header {
            background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
            padding: 10px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--border);
        }

        .cart-card-id {
            font-size: 15px;
            font-weight: 800;
            color: var(--azure);
            font-family: 'Montserrat', sans-serif;
        }

        .cart-card-date {
            font-size: 12px;
            color: var(--muted);
            font-family: 'Montserrat', sans-serif;
        }

        .cart-card-body {
            padding: 12px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .cart-card-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-family: 'Montserrat', sans-serif;
        }

        .cart-card-label {
            font-size: 12px;
            color: var(--muted);
            font-weight: 500;
        }

        .cart-card-value {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
        }

        .cart-card-value.azure { color: var(--azure); }

        .cart-card-footer {
            padding: 10px 16px;
            border-top: 1px solid var(--border-soft);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .cart-action {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            font-size: 18px;
        }

        .cart-current-badge {
            font-size: 12px;
            padding: 4px 12px;
        }
    }
</style>

<%# ===== BREADCRUMB ===== %>
<div class="cart-breadcrumb">
  <%= link_to customer_index_path do %>
    <i class="fa fa-shopping-basket"></i> Продовжити покупку
  <% end %>
  <%= link_to orders_url do %>
    <i class="fa fa-list"></i> До списку замовлень
  <% end %>
  <%= link_to account_url do %>
    <i class="fa fa-home"></i> На головну
  <% end %>
</div>

<div class="cart-page-title">Мої поточні покупки</div>

<%# ===== DESKTOP: ТАБЛИЦЯ ===== %>
<div class="cart-table-wrap">
  <table class="cart-table">
    <thead>
    <tr>
      <th>№</th>
      <th>Дата</th>
      <th>Вага</th>
      <th>Сума</th>
      <th>Покупець</th>
      <th></th>
    </tr>
    </thead>
    <tbody>
    <% @carts.each do |cart| %>
      <% is_current = cart.id == session[:cart_id] %>
      <tr class="<%= is_current ? 'is-current' : '' %>">
        <td><span class="cart-num">#<%= cart.id %></span></td>
        <td><%= cart.created_at.strftime("%d.%m.%Y %H:%M") %></td>
        <td><span class="cart-qty"><%= sprintf("%0.02f кг", cart.total_quantity) %></span></td>
        <td><span class="cart-price"><%= sprintf("%0.02f грн.", cart.total_price) %></span></td>
        <td><%= cart.client&.name || "—" %></td>
        <td>
          <div class="cart-actions-cell">
            <%= link_to cart, class: "cart-action cart-action-open", title: "Відкрити" do %>
              <i class="fa fa-search"></i>
            <% end %>
            <%= link_to cart, method: :delete,
                        data: { confirm: 'Ви впевнені?' },
                        class: "cart-action cart-action-delete", title: "Видалити" do %>
              <i class="fa fa-trash"></i>
            <% end %>
            <% if is_current %>
                <span class="cart-current-badge">
                  <i class="fa fa-hand-o-left"></i> Поточний
                </span>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>

<%# ===== MOBILE: КАРТКИ ===== %>
<div class="cart-cards">
  <% @carts.each do |cart| %>
    <% is_current = cart.id == session[:cart_id] %>
    <div class="cart-card <%= is_current ? 'is-current' : '' %>">

      <div class="cart-card-header">
        <span class="cart-card-id">
          #<%= cart.id %>
          <% if is_current %>
            &nbsp;<span class="cart-current-badge"><i class="fa fa-check"></i> Поточний</span>
          <% end %>
        </span>
        <span class="cart-card-date"><%= cart.created_at.strftime("%d.%m.%Y %H:%M") %></span>
      </div>

      <div class="cart-card-body">
        <div class="cart-card-row">
          <span class="cart-card-label">Покупець</span>
          <span class="cart-card-value"><%= cart.client&.name || "—" %></span>
        </div>
        <div class="cart-card-row">
          <span class="cart-card-label">Вага</span>
          <span class="cart-card-value azure"><%= sprintf("%0.02f кг", cart.total_quantity) %></span>
        </div>
        <div class="cart-card-row">
          <span class="cart-card-label">Сума</span>
          <span class="cart-card-value"><%= sprintf("%0.02f грн.", cart.total_price) %></span>
        </div>
      </div>

      <div class="cart-card-footer">
        <%= link_to cart, class: "cart-action cart-action-open", title: "Відкрити" do %>
          <i class="fa fa-search"></i>
        <% end %>
        <%= link_to cart, method: :delete,
                    data: { confirm: 'Ви впевнені?' },
                    class: "cart-action cart-action-delete", title: "Видалити" do %>
          <i class="fa fa-trash"></i>
        <% end %>
      </div>

    </div>
  <% end %>
</div>