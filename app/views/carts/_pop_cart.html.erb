<style>
    /* ===== POP CART TABLE ===== */
    .pop-cart-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Montserrat', sans-serif;
        font-size: 13px;
    }

    .pop-cart-table tbody tr {
        border-bottom: 1px solid rgba(186,224,245,0.4);
        transition: background .15s;
    }

    .pop-cart-table tbody tr:last-child { border-bottom: none; }
    .pop-cart-table tbody tr:hover { background: rgba(26,122,175,0.03); }

    .pop-cart-td {
        padding: 10px 8px;
        vertical-align: middle;
        color: #0B2A3D;
    }

    /* Назва товару */
    .pop-cart-name {
        font-weight: 600;
        font-size: 13px;
        line-height: 1.3;
        color: #0B2A3D;
        min-width: 140px;
    }

    .pop-cart-pack {
        font-size: 11px;
        color: #4A7A96;
        font-weight: 500;
    }

    /* Поле кількості */
    .pop-cart-qty-input {
        width: 80px;
        background: #F0F8FF;
        border: 1.5px solid #BAE0F5;
        border-radius: 8px;
        color: #0B2A3D;
        padding: 7px 10px;
        font-size: 14px;
        font-family: 'Montserrat', sans-serif;
        font-weight: 600;
        outline: none;
        text-align: center;
        transition: border-color .2s, box-shadow .2s;
        -webkit-appearance: none;
    }

    .pop-cart-qty-input:focus {
        border-color: #3AA0D8;
        box-shadow: 0 0 0 3px rgba(26,122,175,0.10);
        background: #fff;
    }

    /* Одиниця виміру */
    .pop-cart-unit {
        font-size: 12px;
        color: #4A7A96;
        font-weight: 600;
        white-space: nowrap;
    }

    /* Перерахунок кг */
    .pop-cart-recount {
        font-size: 12px;
        color: #1A7AAF;
        font-weight: 700;
        white-space: nowrap;
    }

    /* Кнопка видалити */
    .pop-cart-delete {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 7px;
        color: rgba(192,57,43,0.5);
        font-size: 15px;
        text-decoration: none;
        transition: color .2s, background .2s;
    }

    .pop-cart-delete:hover {
        color: #C0392B;
        background: rgba(192,57,43,0.1);
    }

    /* Порожній кошик */
    .pop-cart-empty {
        text-align: center;
        padding: 24px;
        color: #4A7A96;
        font-family: 'Montserrat', sans-serif;
        font-size: 14px;
    }

    @media (max-width: 600px) {
        .pop-cart-qty-input { width: 70px; font-size: 16px; }
        .pop-cart-name { font-size: 14px; }
        .pop-cart-td { padding: 10px 5px; }

        /* Ховаємо кнопку Закрити у footer кошика на мобільному */
        .cart-close-desktop { display: none !important; }
    }
</style>

<% if @cart.nil? || @cart.line_items.empty? %>
  <div class="pop-cart-empty">
    <i class="fa fa-shopping-cart" style="font-size:28px; opacity:0.3; display:block; margin-bottom:8px;"></i>
    Кошик порожній
  </div>
<% else %>
  <table class="pop-cart-table">
    <tbody>
    <% @cart&.line_items&.order(:id)&.each do |line_item| %>
      <% pack_name = line_item.pack_id.nil? ? nil : Pack.find(line_item.pack_id).name %>
      <tr>
        <%# Назва %>
        <td class="pop-cart-td">
          <div class="pop-cart-name"><%= line_item.product.title %></div>
          <% if pack_name %>
            <div class="pop-cart-pack"><%= pack_name %></div>
          <% end %>
        </td>

        <%# Кількість %>
        <td class="pop-cart-td">
          <%= number_field_tag 'qty' + line_item.id.to_s,
                               line_item.amount + line_item.quantity,
                               step: 0.01,
                               class: "pop-cart-qty-input",
                               id: 'qty' + line_item.id.to_s,
                               onchange: "inputFieldOnChange(this)" %>
        </td>

        <%# Одиниця %>
        <td class="pop-cart-td pop-cart-unit">
          <%= Unit.find(line_item.unit_id).name %>
        </td>

        <%# Перерахунок %>
        <td class="pop-cart-td pop-cart-recount">
          <%= display_recount(line_item.recount).to_s %> кг
        </td>

        <%# Видалити %>
        <td class="pop-cart-td" style="text-align:center;">
          <%= link_to destroy_from_pop_cart_path(id: line_item),
                      method: :delete,
                      remote: true,
                      class: 'pop-cart-delete',
                      title: 'Видалити' do %>
            <i class="fa fa-trash"></i>
          <% end %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
<% end %>