<style>
    :root {
        --azure:        #1A7AAF;
        --azure-light:  #3AA0D8;
        --bg:           #F0F8FF;
        --surface:      #FFFFFF;
        --border:       #BAE0F5;
        --border-soft:  #D4EDF9;
        --text:         #0B2A3D;
        --muted:        #4A7A96;
        --red:          #C0392B;
    }

    .usr-breadcrumb {
        display: flex; align-items: center; gap: 6px;
        margin-bottom: 24px; flex-wrap: wrap;
    }
    .usr-breadcrumb a {
        display: inline-flex; align-items: center; gap: 5px;
        color: var(--azure); text-decoration: none; font-weight: 600;
        padding: 6px 14px; border-radius: 20px; font-size: 13px;
        background: rgba(26,122,175,0.07); border: 1px solid rgba(26,122,175,0.18);
        font-family: 'Montserrat', sans-serif; transition: background 0.2s;
    }
    .usr-breadcrumb a:hover { background: rgba(26,122,175,0.14); }
    .usr-breadcrumb span { color: var(--muted); font-size: 13px; font-family: 'Montserrat', sans-serif; }

    .usr-notice {
        background: rgba(14,112,64,0.08); border: 1px solid rgba(14,112,64,0.2);
        border-radius: 10px; padding: 10px 16px; color: #0E7040;
        font-size: 13px; margin-bottom: 16px; font-family: 'Montserrat', sans-serif;
    }

    .usr-page-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 20px; flex-wrap: wrap; gap: 12px;
    }

    .usr-page-title {
        font-family: 'Playfair Display', serif;
        font-size: 24px; font-weight: 800; color: var(--text);
        display: flex; align-items: center; gap: 10px;
    }
    .usr-page-title::before {
        content: ''; display: inline-block; width: 5px; height: 24px;
        background: linear-gradient(180deg, var(--azure-light), var(--azure));
        border-radius: 3px;
    }

    .usr-btn-new {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 9px 20px;
        background: linear-gradient(135deg, var(--azure-light), var(--azure));
        border: none; border-radius: 10px; color: #fff;
        font-size: 13px; font-weight: 700; font-family: 'Montserrat', sans-serif;
        text-decoration: none; cursor: pointer;
        transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 3px 12px rgba(26,122,175,0.25);
    }
    .usr-btn-new:hover {
        opacity: 0.92; transform: translateY(-1px); color: #fff;
        box-shadow: 0 6px 18px rgba(26,122,175,0.32); text-decoration: none;
    }

    .usr-table-wrap {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: 16px; overflow-x: auto;
        box-shadow: 0 2px 12px rgba(26,122,175,0.07);
        -webkit-overflow-scrolling: touch;
    }

    .usr-table {
        width: 100%; min-width: 600px; border-collapse: collapse;
        font-size: 13px; font-family: 'Montserrat', sans-serif;
    }

    .usr-table thead tr {
        background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
        border-bottom: 2px solid var(--border);
    }

    .usr-table thead th {
        padding: 12px 16px; font-size: 11px; letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--azure); font-weight: 700;
        white-space: nowrap; text-align: left;
        position: sticky; top: 0;
        background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
        z-index: 2; box-shadow: 0 2px 0 var(--border);
    }

    .usr-table tbody tr {
        border-bottom: 1px solid rgba(186,224,245,0.4);
        transition: background 0.15s;
    }
    .usr-table tbody tr:last-child { border-bottom: none; }
    .usr-table tbody tr:hover { background: rgba(26,122,175,0.04); }

    .usr-table td {
        padding: 11px 16px; color: var(--text); vertical-align: middle;
    }

    .usr-action {
        display: inline-flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; border-radius: 8px; font-size: 14px;
        text-decoration: none; transition: background 0.2s, transform 0.15s;
    }
    .usr-action-edit {
        color: var(--azure); background: rgba(26,122,175,0.07);
        border: 1px solid rgba(26,122,175,0.15);
    }
    .usr-action-edit:hover { background: rgba(26,122,175,0.14); transform: scale(1.08); }
    .usr-action-delete {
        color: var(--red); background: rgba(192,57,43,0.07);
        border: 1px solid rgba(192,57,43,0.15);
    }
    .usr-action-delete:hover { background: rgba(192,57,43,0.14); transform: scale(1.08); }
</style>

<div class="usr-breadcrumb">
  <%= link_to account_url do %><i class="fa fa-home"></i> На головну<% end %>
  <span>/</span>
  <%= link_to admin_url do %><i class="fa fa-cogs"></i> Адміністрування<% end %>
  <span>/</span>
  <span>Користувачі</span>
</div>

<% if notice.present? %>
  <div class="usr-notice"><%= notice %></div>
<% end %>

<div class="usr-page-header">
  <div class="usr-page-title">Користувачі</div>
  <%= link_to new_user_path, class: 'usr-btn-new' do %>
    <i class="fa fa-plus"></i> Новий користувач
  <% end %>
</div>

<div class="usr-table-wrap">
  <table class="usr-table">
    <thead>
    <tr>
      <th>Ім'я</th>
      <th>Роль</th>
      <th>Підрозділ</th>
      <th>Група доступу</th>
      <th>Код</th>
      <th colspan="2"></th>
    </tr>
    </thead>
    <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.role %></td>
        <td><%= user.storage_place.nil? ? 'Не задано' : user.storage_place.title %></td>
        <th><%= user.access_group.nil? ? 'Не задано' : user.access_group.name %></th>
        <td><%= user.unf_id %></td>
        <td>
          <%= link_to edit_user_path(user), class: 'usr-action usr-action-edit', title: 'Редагувати' do %>
            <i class="fa fa-pencil"></i>
          <% end %>
        </td>
        <td>
          <%= link_to user, method: :delete, data: { confirm: 'Ви дійсно бажаєте видалити?' }, class: 'usr-action usr-action-delete', title: 'Видалити' do %>
            <i class="fa fa-trash"></i>
          <% end %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>