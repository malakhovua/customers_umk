<style>
    :root {
        --azure:        #1A7AAF;
        --azure-light:  #3AA0D8;
        --azure-bright: #0EA5E9;
        --teal:         #0E7490;
        --bg:           #F0F8FF;
        --surface:      #FFFFFF;
        --border:       #BAE0F5;
        --border-soft:  #D4EDF9;
        --text:         #0B2A3D;
        --muted:        #4A7A96;
    }

    /* Повністю перекриваємо Bootstrap layout за допомогою position:fixed */
    .login-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: var(--bg);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow-y: auto;
    }

    .login-overlay::before {
        content: '';
        position: fixed;
        top: -200px; left: -180px;
        width: 600px; height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(26,122,175,0.12) 0%, transparent 70%);
        pointer-events: none;
    }

    .login-overlay::after {
        content: '';
        position: fixed;
        bottom: -180px; right: -140px;
        width: 500px; height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(14,116,144,0.10) 0%, transparent 70%);
        pointer-events: none;
    }

    /* Картка — десктоп */
    .login-card {
        position: relative;
        z-index: 1;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 48px 44px 44px;
        width: 90%;
        max-width: 440px;
        box-shadow: 0 4px 24px rgba(26,122,175,0.10);
        animation: fadeUp 0.55s ease both;
    }

    /* Картка — мобільний: на весь екран */
    @media (max-width: 600px) {
        .login-overlay {
            align-items: flex-start;
        }

        /* form всередині overlay теж має займати весь екран */
        .login-overlay > form {
            width: 100%;
            min-height: 100vh;
            min-height: 100dvh;
            display: flex;
            flex-direction: column;
        }

        .login-card {
            width: 100%;
            max-width: 100%;
            flex: 1;
            min-height: 100vh;
            min-height: 100dvh;
            border-radius: 0;
            padding: 72px 28px 48px;
            border: none;
            box-shadow: none;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
    }

    .login-emblem {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 28px;
        gap: 12px;
    }

    .login-emblem-icon {
        width: 120px; height: 120px;
        border-radius: 50%;
        flex-shrink: 0;
        animation: fadeUp 0.7s ease both;
    }

    .login-emblem-icon img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 50%;
    }

    .login-brand {
        font-family: 'Playfair Display', serif;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        text-align: center;
        background: linear-gradient(135deg, var(--teal), var(--azure), var(--azure-bright));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.4;
    }

    .login-title {
        font-family: 'Playfair Display', serif;
        font-size: 30px;
        font-weight: 900;
        color: var(--text);
        text-align: center;
        margin-bottom: 6px;
    }

    .login-subtitle {
        font-size: 13px;
        color: var(--muted);
        text-align: center;
        margin-bottom: 28px;
        line-height: 1.5;
    }

    .login-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
    }

    .login-divider-line {
        flex: 1; height: 1px;
        background: linear-gradient(to right, transparent, var(--border), transparent);
    }

    .login-divider-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
        background: var(--azure-light);
        opacity: 0.5;
    }

    .login-field { margin-bottom: 18px; }

    .login-label {
        display: block;
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--azure);
        font-weight: 700;
        margin-bottom: 7px;
    }

    .login-input-wrap { position: relative; }

    .login-input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-size: 15px;
        pointer-events: none;
        transition: color 0.2s;
    }

    .login-input {
        width: 100%;
        background: var(--bg);
        border: 1.5px solid var(--border);
        border-radius: 12px;
        color: var(--text);
        padding: 13px 14px 13px 42px;
        font-size: 16px;
        font-family: 'Montserrat', sans-serif;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        -webkit-appearance: none;
    }

    .login-input::placeholder { color: rgba(74,122,150,0.4); }

    .login-input:focus {
        border-color: var(--azure-light);
        box-shadow: 0 0 0 3px rgba(26,122,175,0.12);
        background: var(--surface);
    }

    .login-input-wrap:focus-within .login-input-icon { color: var(--azure); }

    .login-btn {
        width: 100%;
        padding: 14px 20px;
        margin-top: 8px;
        background: linear-gradient(135deg, var(--azure-light), var(--azure));
        border: none;
        border-radius: 12px;
        color: #fff;
        font-size: 15px;
        font-weight: 700;
        font-family: 'Montserrat', sans-serif;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 18px rgba(26,122,175,0.30);
        -webkit-appearance: none;
    }

    .login-btn:hover {
        opacity: 0.92;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(26,122,175,0.38);
    }

    .login-btn:active { transform: translateY(0); }

    .login-card-footer {
        margin-top: 28px;
        padding-top: 16px;
        border-top: 1px solid var(--border-soft);
        text-align: center;
    }

    .login-card-footer span {
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        opacity: 0.6;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

</style>

<div class="login-overlay">
  <%= form_tag do %>
    <div class="login-card">

      <div class="login-emblem">
        <div class="login-emblem-icon"><img src="data:image/png;base64," alt="УМК"></div>
        <div class="login-brand">Український М'ясокомбінат</div>

      </div>

      <div class="login-title">Вхід</div>
      <div class="login-subtitle">Будь ласка, введіть свій логін та пароль</div>

      <div class="login-divider">
        <div class="login-divider-line"></div>
        <div class="login-divider-dot"></div>
        <div class="login-divider-line"></div>
      </div>

      <div class="login-field">
        <label class="login-label" for="username">Ім'я або Email</label>
        <div class="login-input-wrap">
          <%= text_field_tag :name, params[:name],
                             id: "username",
                             class: "login-input",
                             placeholder: "Введіть ім'я або email",
                             autocomplete: "username" %>
          <i class="fa fa-user login-input-icon"></i>
        </div>
      </div>

      <div class="login-field">
        <label class="login-label" for="password">Пароль</label>
        <div class="login-input-wrap">
          <%= password_field_tag :password, params[:password],
                                 id: "password",
                                 class: "login-input",
                                 placeholder: "Введіть пароль",
                                 autocomplete: "current-password" %>
          <i class="fa fa-lock login-input-icon"></i>
        </div>
      </div>

      <%= submit_tag "Увійти →", class: "login-btn" %>

      <div class="login-card-footer">
        <span>Система управління замовленнями</span>
      </div>

    </div>
  <% end %>
</div>