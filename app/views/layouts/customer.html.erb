<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Каталог — Український М'ясокомбінат</title>

  <%# Шрифти %>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">

  <%# Font Awesome %>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

  <%# Bootstrap потрібен тільки для Modal та Pagination — підключаємо лише JS, CSS — свій %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <%# Наші стилі %>
  <%= stylesheet_link_tag "sidebar" %>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
          height: 100%;
          background: #F0F8FF;
          font-family: 'Montserrat', sans-serif;
          -webkit-text-size-adjust: 100%;
      }

      /* ============================================
         BOOTSTRAP MODAL — повний необхідний CSS
         ============================================ */

      /* Базові */
      .fade { transition: opacity .15s linear; }
      .fade:not(.show) { opacity: 0; }

      /* Backdrop */
      .modal-backdrop {
          position: fixed;
          inset: 0;
          z-index: 1040;
          background: rgba(0,0,0,0.5);
      }
      .modal-backdrop.fade { opacity: 0; }
      .modal-backdrop.show { opacity: 0.5; }

      /* Modal обгортка */
      .modal {
          display: none;
          position: fixed;
          inset: 0;
          z-index: 1055;
          overflow-x: hidden;
          overflow-y: auto;
          outline: 0;
      }
      .modal.show { display: block; }

      /* Dialog */
      .modal-dialog {
          position: relative;
          width: auto;
          max-width: 500px;
          margin: 1.75rem auto;
          pointer-events: none;
          transition: transform .3s ease-out;
          transform: translate(0, -50px);
      }
      .modal.show .modal-dialog {
          transform: none;
      }
      .modal-dialog-centered {
          display: flex;
          align-items: center;
          min-height: calc(100% - 3.5rem);
      }
      .modal-dialog-scrollable {
          height: calc(100% - 3.5rem);
      }
      .modal-dialog-scrollable .modal-content {
          max-height: 100%;
          overflow: hidden;
      }
      .modal-dialog-scrollable .modal-body {
          overflow-y: auto;
      }

      /* Content */
      .modal-content {
          position: relative;
          display: flex;
          flex-direction: column;
          width: 100%;
          pointer-events: auto;
          background: #fff;
          border-radius: 16px;
          overflow: hidden;
          box-shadow: 0 8px 32px rgba(26,122,175,0.2);
          outline: 0;
      }

      /* Header */
      .modal-header {
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 18px 24px;
          background: linear-gradient(135deg, #E0F2FF, #C8E8FA);
          border-bottom: 2px solid #BAE0F5;
          flex-shrink: 0;
      }
      .modal-title {
          font-family: 'Playfair Display', serif;
          font-size: 20px;
          font-weight: 800;
          color: #0B2A3D;
          margin: 0;
          line-height: 1.5;
      }
      .modal-header .btn-close,
      .modal-header .close {
          display: flex;
          align-items: center;
          justify-content: center;
          width: 32px;
          height: 32px;
          border-radius: 8px;
          background: rgba(192,57,43,0.08);
          border: 1px solid rgba(192,57,43,0.15);
          font-size: 22px;
          line-height: 1;
          color: #E74C3C;
          opacity: 1;
          cursor: pointer;
          transition: all 0.2s;
          padding: 0;
      }
      .modal-header .btn-close:hover,
      .modal-header .close:hover {
          background: rgba(192,57,43,0.15);
          transform: scale(1.08);
      }

      /* Body */
      .modal-body {
          position: relative;
          flex: 1 1 auto;
          padding: 20px 24px;
          overflow-y: auto;
      }

      /* Footer */
      .modal-footer {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 12px;
          padding: 16px 24px;
          border-top: 1px solid #BAE0F5;
          background: rgba(26,122,175,0.04);
          flex-shrink: 0;
          flex-wrap: wrap;
      }

      /* Кнопки в modal */
      .modal-footer .btn,
      .modal-footer button.btn {
          display: inline-flex;
          align-items: center;
          gap: 6px;
          padding: 10px 20px;
          border-radius: 10px;
          font-family: 'Montserrat', sans-serif;
          font-size: 14px;
          font-weight: 600;
          cursor: pointer;
          transition: all 0.2s;
          border: none;
          text-decoration: none;
      }
      .modal-footer .btn-secondary {
          background: rgba(74,122,150,0.12);
          border: 1px solid rgba(74,122,150,0.25);
          color: #4A7A96;
      }
      .modal-footer .btn-secondary:hover {
          background: rgba(74,122,150,0.2);
          color: #0B2A3D;
      }
      .modal-footer .btn-primary {
          background: #1A7AAF;
          border: 1px solid #125A7F;
          color: #fff;
          box-shadow: 0 2px 8px rgba(26,122,175,0.3);
      }
      .modal-footer .btn-primary:hover:not(:disabled) {
          background: #3AA0D8;
          transform: translateY(-1px);
          box-shadow: 0 4px 12px rgba(26,122,175,0.4);
      }
      .modal-footer .btn-primary:disabled {
          background: rgba(74,122,150,0.3);
          cursor: not-allowed;
      }

      /* Alert всередині modal */
      .modal .alert {
          padding: 12px 16px;
          border-radius: 10px;
          font-family: 'Montserrat', sans-serif;
          font-size: 14px;
          font-weight: 600;
          margin: 12px 24px 0;
      }
      .modal .alert-danger {
          background: rgba(192,57,43,0.1);
          border: 1px solid rgba(192,57,43,0.3);
          color: #C0392B;
      }

      /* Modal розміри */
      .modal-sm { max-width: 300px; }
      .modal-lg { max-width: 800px; }
      .modal-xl { max-width: 1140px; }

      /* Mobile modal */
      @media (max-width: 600px) {
          .modal-dialog {
              margin: 8px;
              max-width: calc(100vw - 16px);
          }
          .modal-title { font-size: 18px; }
          .modal-footer .btn {
              font-size: 15px;
              padding: 13px 20px;
              border-radius: 12px;
              flex: 1;
              justify-content: center;
          }
      }

      /* Navbar відступ зверху */
      #page-content-wrapper {
          padding-top: 70px;
      }

      @media (max-width: 600px) {
          #page-content-wrapper {
              padding-top: 64px;
          }
      }
  </style>
</head>
<body>
<%= yield %>

<%# jQuery (потрібен для sidebar.js) %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<%# Rails UJS %>
<%= javascript_include_tag "application", "data-turbo-track": "reload" %>
</body>
</html>